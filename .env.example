# Puchuku Backend Configuration
# Copy this to .env and fill in your values

# Server Port
PORT=3001

# Set to production to serve React app from dist folder
NODE_ENV=production

# Database Configuration (for PHP API - optional, not used by Node backend)
# DB_HOST=localhost
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=puchuku_db